---
/**
 * Footer — FIREFIGHTER México
 * Diseño profesional B2B. Dark #09090b, accent #dc2626.
 * Estructura: Pre-footer CTA → Main (5 cols) → Certs strip → Bottom bar
 */

const currentYear = new Date().getFullYear();
const siteUrl = 'https://firefighter.com.mx';
const waBase = 'https://wa.me/525500000000';

const productos = [
  { label: 'Equipos para Bomberos',      href: `${waBase}?text=Hola%2C%20necesito%20equipo%20para%20bomberos` },
  { label: 'Trajes y EPP Estructural',   href: `${waBase}?text=Hola%2C%20necesito%20trajes%20estructurales%20NFPA` },
  { label: 'SCBA y Respiración',         href: `${waBase}?text=Hola%2C%20necesito%20equipos%20SCBA` },
  { label: 'Extintores Industriales',    href: `${waBase}?text=Hola%2C%20necesito%20extintores%20industriales` },
  { label: 'Sistemas de Supresión',      href: `${waBase}?text=Hola%2C%20necesito%20sistemas%20de%20supresion` },
  { label: 'Herramientas de Rescate',    href: `${waBase}?text=Hola%2C%20necesito%20herramientas%20de%20rescate` },
  { label: 'Gabinetes y Mangueras',      href: `${waBase}?text=Hola%2C%20necesito%20gabinetes%20contra%20incendio` },
  { label: 'Detección y Alarma',         href: `${waBase}?text=Hola%2C%20necesito%20sistemas%20de%20deteccion` },
];

const sectores = [
  { label: 'Cuerpos de Bomberos',        href: `${waBase}?text=Hola%2C%20soy%20bombero%20y%20necesito%20equipo` },
  { label: 'Industria y Manufactura',    href: `${waBase}?text=Hola%2C%20necesito%20equipo%20para%20industria` },
  { label: 'Hospitales y Salud',         href: `${waBase}?text=Hola%2C%20necesito%20equipo%20para%20hospital` },
  { label: 'Hoteles y Plazas',           href: `${waBase}?text=Hola%2C%20necesito%20equipo%20para%20hotel` },
  { label: 'Construcción y Proyectos',   href: `${waBase}?text=Hola%2C%20necesito%20equipo%20para%20construccion` },
  { label: 'Gobierno y Licitaciones',    href: `${waBase}?text=Hola%2C%20necesito%20equipo%20para%20licitacion` },
  { label: 'Escuelas y Universidades',   href: `${waBase}?text=Hola%2C%20necesito%20equipo%20para%20escuela` },
  { label: 'Aeropuertos y Logística',    href: `${waBase}?text=Hola%2C%20necesito%20equipo%20para%20aeropuerto` },
];

const empresa = [
  { label: 'Nosotros',                   href: '/nosotros' },
  { label: 'Marcas que distribuimos',    href: '/marcas' },
  { label: 'Casos de éxito',             href: '/casos' },
  { label: 'Blog de seguridad',          href: '/blog' },
  { label: 'Cotización en 24 h',         href: `${waBase}?text=Hola%2C%20necesito%20una%20cotizacion` },
  { label: 'Licitaciones públicas',      href: 'mailto:licitaciones@firefighter.mx' },
  { label: 'Soporte y garantía',         href: 'mailto:soporte@firefighter.mx' },
];

const legal = [
  { label: 'Aviso de Privacidad',        href: '/privacidad' },
  { label: 'Términos y Condiciones',     href: '/terminos' },
  { label: 'Política de Garantías',      href: '/garantias' },
  { label: 'Política de Devoluciones',   href: '/devoluciones' },
  { label: 'Mapa del Sitio',             href: '/sitemap.xml' },
];

const certs = [
  { label: 'NFPA 1971',   sub: 'Trajes estructurales' },
  { label: 'NFPA 1981',   sub: 'Equipos SCBA' },
  { label: 'NFPA 13',     sub: 'Sistemas sprinkler' },
  { label: 'NFPA 72',     sub: 'Detección y alarma' },
  { label: 'NOM-002-STPS',sub: 'Brigadas industriales' },
  { label: 'UL Listed',   sub: 'Productos certificados' },
  { label: 'FM Approvals',sub: 'Sistemas fijos' },
];

const socialLinks = [
  {
    name: 'Facebook',
    href: 'https://facebook.com/firefightermx',
    icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
  {
    name: 'Instagram',
    href: 'https://instagram.com/firefightermx',
    icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z',
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com/company/firefightermx',
    icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    name: 'YouTube',
    href: 'https://youtube.com/@firefightermx',
    icon: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
  },
];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  "name": "FIREFIGHTER México",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/images/logo-firefighter.svg`,
    "width": 200,
    "height": 50,
  },
  "description": "Venta de equipos contra incendios y equipos para bomberos en México. Trajes NFPA, SCBA, extintores, sistemas de supresión y herramientas de rescate certificados.",
  "areaServed": { "@type": "Country", "name": "México", "identifier": "MX" },
  "sameAs": socialLinks.map(s => s.href),
  "contactPoint": [
    { "@type": "ContactPoint", "contactType": "sales",   "email": "ventas@firefighter.mx",       "availableLanguage": "Spanish" },
    { "@type": "ContactPoint", "contactType": "customer support", "email": "soporte@firefighter.mx", "availableLanguage": "Spanish" },
  ],
};
---

<footer>

  <!-- ════════════════════════════════════════════
       PRE-FOOTER — CTA WhatsApp
  ════════════════════════════════════════════ -->
  <div style="background:#dc2626; padding:56px 0;">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10" style="align-items:center;">

        <div>
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
            <span style="display:block; width:24px; height:2px; background:rgba(255,255,255,0.5); flex-shrink:0; border-radius:2px;"></span>
            <span style="font-size:0.68rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:rgba(255,255,255,0.7);">Cotiza en menos de 24 horas</span>
          </div>
          <h2 style="font-size:clamp(1.6rem,2.4vw,2.3rem); font-weight:800; color:#fff; line-height:1.1; margin:0; letter-spacing:-0.02em;">
            ¿Listo para equipar tu brigada<br>o proyecto contra incendios?
          </h2>
        </div>

        <div style="display:flex; flex-direction:column; gap:14px;">
          <p style="font-size:0.9rem; color:rgba(255,255,255,0.8); line-height:1.8; margin:0;">
            Ingenieros especializados en <strong style="color:#fff;">NFPA y NOM-002-STPS</strong> analizan tu tipo de riesgo y te recomiendan el equipo exacto. Sin costo, sin compromiso.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:12px; margin-top:4px;">
            <a
              href={`${waBase}?text=Hola%2C%20necesito%20una%20cotizaci%C3%B3n%20de%20equipo%20contra%20incendios`}
              target="_blank"
              rel="noopener"
              style="display:inline-flex; align-items:center; gap:10px; padding:14px 28px; background:#fff; color:#dc2626; font-size:0.9rem; font-weight:700; border-radius:10px; text-decoration:none; letter-spacing:0.01em; transition:background 0.2s;"
              onmouseover="this.style.background='#fef2f2'"
              onmouseout="this.style.background='#fff'"
            >
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Cotizar por WhatsApp
            </a>
            <a
              href="mailto:licitaciones@firefighter.mx"
              style="display:inline-flex; align-items:center; gap:10px; padding:14px 28px; background:rgba(0,0,0,0.2); color:#fff; font-size:0.9rem; font-weight:700; border-radius:10px; text-decoration:none; border:1px solid rgba(255,255,255,0.25); transition:background 0.2s;"
              onmouseover="this.style.background='rgba(0,0,0,0.35)'"
              onmouseout="this.style.background='rgba(0,0,0,0.2)'"
            >
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Licitaciones públicas
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ════════════════════════════════════════════
       MAIN FOOTER — 5 columnas
  ════════════════════════════════════════════ -->
  <div style="background:#09090b; padding:72px 0 56px;">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8">

        <!-- Col 1 — Brand (ocupa 2 cols en lg) -->
        <div class="lg:col-span-2" style="padding-right:2rem;">

          <!-- Logo -->
          <a href="/" style="display:inline-flex; align-items:center; gap:12px; margin-bottom:24px; text-decoration:none;">
            <div style="width:44px; height:44px; background:#dc2626; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <svg width="24" height="24" fill="white" viewBox="0 0 24 24">
                <path d="M12 2C12 2 7 8 7 13C7 16.866 9.239 20 12 20C14.761 20 17 16.866 17 13C17 8 12 2 12 2Z"/>
                <path d="M12 10C12 10 9.5 13 9.5 15C9.5 16.381 10.619 17.5 12 17.5C13.381 17.5 14.5 16.381 14.5 15C14.5 13 12 10 12 10Z" fill="rgba(255,255,255,0.5)"/>
              </svg>
            </div>
            <div>
              <span style="font-size:1.15rem; font-weight:800; color:#fff; display:block; letter-spacing:-0.01em; line-height:1.1;">FIREFIGHTER</span>
              <span style="font-size:0.68rem; color:#71717a; letter-spacing:0.08em; text-transform:uppercase;">México · Equipo Profesional</span>
            </div>
          </a>

          <p style="font-size:0.82rem; color:#71717a; line-height:1.85; margin:0 0 24px; max-width:300px;">
            Distribuidores autorizados de <strong style="color:#a1a1aa; font-weight:600;">MSA Safety, Scott, Holmatro y Amerex</strong>. Equipamos cuerpos de bomberos, brigadas industriales y proyectos contra incendios en los 32 estados de México.
          </p>

          <!-- Datos de contacto -->
          <div style="display:flex; flex-direction:column; gap:12px; margin-bottom:28px;">
            <a href={`${waBase}?text=Hola%2C%20necesito%20informaci%C3%B3n`} target="_blank" rel="noopener" style="display:flex; align-items:center; gap:10px; text-decoration:none; color:#a1a1aa; font-size:0.82rem; transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#a1a1aa'">
              <span style="width:32px; height:32px; background:#1a1a1a; border-radius:7px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="14" height="14" fill="#52525b" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </span>
              WhatsApp · Asesoría sin costo
            </a>
            <a href="mailto:ventas@firefighter.mx" style="display:flex; align-items:center; gap:10px; text-decoration:none; color:#a1a1aa; font-size:0.82rem; transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#a1a1aa'">
              <span style="width:32px; height:32px; background:#1a1a1a; border-radius:7px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="14" height="14" fill="none" stroke="#52525b" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </span>
              ventas@firefighter.mx
            </a>
            <a href="mailto:licitaciones@firefighter.mx" style="display:flex; align-items:center; gap:10px; text-decoration:none; color:#a1a1aa; font-size:0.82rem; transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#a1a1aa'">
              <span style="width:32px; height:32px; background:#1a1a1a; border-radius:7px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="14" height="14" fill="none" stroke="#52525b" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </span>
              licitaciones@firefighter.mx
            </a>
          </div>

          <!-- Redes sociales -->
          <div style="display:flex; gap:8px;">
            {socialLinks.map(s => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.name}
                style="width:36px; height:36px; background:#1a1a1a; border-radius:8px; display:flex; align-items:center; justify-content:center; transition:background 0.2s;"
                onmouseover="this.style.background='#dc2626'"
                onmouseout="this.style.background='#1a1a1a'"
              >
                <svg width="15" height="15" fill="#71717a" viewBox="0 0 24 24">
                  <path d={s.icon} />
                </svg>
              </a>
            ))}
          </div>

        </div>

        <!-- Col 2 — Productos -->
        <div>
          <h4 style="font-size:0.68rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#fff; margin:0 0 20px;">
            Productos
          </h4>
          <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
            {productos.map(l => (
              <li>
                <a
                  href={l.href}
                  target={l.href.startsWith('http') ? '_blank' : undefined}
                  rel={l.href.startsWith('http') ? 'noopener' : undefined}
                  style="font-size:0.8rem; color:#71717a; text-decoration:none; transition:color 0.2s; display:flex; align-items:center; gap:8px;"
                  onmouseover="this.style.color='#fff'"
                  onmouseout="this.style.color='#71717a'"
                >
                  <span style="display:block; width:3px; height:3px; background:#3f3f46; border-radius:50%; flex-shrink:0;"></span>
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Col 3 — Sectores -->
        <div>
          <h4 style="font-size:0.68rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#fff; margin:0 0 20px;">
            Sectores
          </h4>
          <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
            {sectores.map(l => (
              <li>
                <a
                  href={l.href}
                  target="_blank"
                  rel="noopener"
                  style="font-size:0.8rem; color:#71717a; text-decoration:none; transition:color 0.2s; display:flex; align-items:center; gap:8px;"
                  onmouseover="this.style.color='#fff'"
                  onmouseout="this.style.color='#71717a'"
                >
                  <span style="display:block; width:3px; height:3px; background:#3f3f46; border-radius:50%; flex-shrink:0;"></span>
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Col 4 — Empresa + Legal -->
        <div>
