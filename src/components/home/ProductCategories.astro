    sectors: ['Rescate vehicular', 'Derrumbes', 'Rescate urbano'],
    highlight: 'Distribuidor Holmatro',
    link: 'Herramientas%20de%20Rescate',
  },
  {
    img: 'https://images.unsplash.com/photo-1596524430615-b46475ddff6e?auto=format&fit=crop&w=600&h=360&q=80',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>`,
