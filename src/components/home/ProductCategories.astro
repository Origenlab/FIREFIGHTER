---
/**
 * ProductCategories — Catálogo de productos
 * Estilo: card header dark + foto real, body blanco limpio (proyectored pattern)
 */

const categories = [
  {
    img: 'https://images.unsplash.com/photo-1614738529830-d9e37e4d14be?auto=format&fit=crop&w=600&h=360&q=80',
