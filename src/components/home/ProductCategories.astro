    sectors: ['Edificios', 'Hoteles', 'Industria'],
    highlight: 'Sistemas Honeywell · Notifier',
    link: 'Detecci%C3%B3n%20y%20Alarma',
  },
  {
    img: 'https://images.unsplash.com/photo-1562774053-701939374585?auto=format&fit=crop&w=600&h=360&q=80',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>`,
    title: 'Señalética y Seguridad',
    desc: 'Señalización fotoluminiscente y LED certificada NOM-003-SEGOB, luces de emergencia y kits de evacuación para cumplimiento de protección civil.',
    badge: 'NOM-003',
    products: ['Señalética fotoluminiscente', 'Luces de evacuación LED', 'Lámparas de emergencia', 'Botiquines NOM-005', 'Kits de evacuación', 'Planos de emergencia'],
    sectors: ['Comercios', 'Escuelas', 'Oficinas corporativas'],
    highlight: 'Cumplimiento NOM + SGPC',
    link: 'Se%C3%B1al%C3%A9tica%20y%20Seguridad',
  },
];
---

<section id="productos" style="background: #ffffff; padding: 80px 0 96px;">
  <div class="container-custom">

    <!-- ── Header dos columnas 50/50 ── -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16" style="align-items:center; margin-bottom:56px;">

      <!-- Columna izquierda -->
      <div>
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
          <span style="display:block; width:24px; height:2px; background:#dc2626; flex-shrink:0; border-radius:2px;"></span>
          <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#dc2626;">Catálogo de Productos</span>
        </div>
        <h2 style="font-size:clamp(1.9rem,2.8vw,2.7rem); font-weight:800; color:#09090b; line-height:1.1; margin:0 0 20px; letter-spacing:-0.02em;">
          Equipo Profesional<br>para Cada Necesidad
        </h2>
        <p style="font-size:1rem; color:#71717a; line-height:1.8; margin:0;">
          Desde EPP para bomberos hasta sistemas de supresión industrial. Todo certificado con asesoría técnica especializada incluida sin costo.
        </p>
      </div>

      <!-- Columna derecha: dos párrafos SEO/marketing -->
      <div style="display:flex; flex-direction:column; gap:28px;">

        <div>
          <span style="display:block; font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#09090b; margin-bottom:10px;">Distribución Autorizada en México</span>
          <p style="font-size:0.9rem; color:#52525b; line-height:1.85; margin:0;">
            FIREFIGHTER es distribuidor autorizado de las marcas líderes en equipamiento contra incendios: <strong style="color:#09090b; font-weight:600;">MSA Safety, Scott Aviation, Holmatro y Amerex</strong>. Cada producto incluye certificado de origen, número de serie trazable y ficha técnica en español, documentación esencial para licitaciones públicas, auditorías de protección civil y verificaciones NOM en los 32 estados de la República Mexicana.
          </p>
        </div>

        <div style="padding-top:28px; border-top:1px solid #f0f0f0;">
          <span style="display:block; font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#09090b; margin-bottom:10px;">Asesoría Técnica Especializada sin Costo</span>
          <p style="font-size:0.9rem; color:#52525b; line-height:1.85; margin:0;">
            Nuestro equipo de ingenieros certificados en <strong style="color:#09090b; font-weight:600;">NFPA, NOM-002-STPS y protección civil</strong> analiza el tipo de riesgo, la norma aplicable y el presupuesto de cada proyecto para recomendar el equipo exacto. Propuesta técnica detallada con especificaciones, precios y tiempos de entrega en menos de 24 horas hábiles, sin compromiso de compra.
          </p>
        </div>

      </div>

    </div>

    <!-- ── Grid de cards ── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {categories.map((cat) => (
        <article style="background:#fff; border:1px solid #e4e4e7; border-radius:14px; overflow:hidden; display:flex; flex-direction:column; transition:box-shadow 0.2s ease, transform 0.2s ease;" class="group hover:-translate-y-1 hover:shadow-lg">

          <!-- Header: foto real + overlay oscuro -->
          <div style={`height:180px; background-color:#111; background-image:url('${cat.img}'); background-size:cover; background-position:center; position:relative; flex-shrink:0;`}>
            <!-- Overlay gradiente -->
            <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.08) 0%,rgba(0,0,0,0.55) 100%);"></div>
            <!-- Badge norma -->
            <span style="position:absolute;top:12px;left:12px;background:#dc2626;color:#fff;font-size:0.62rem;font-weight:800;letter-spacing:0.06em;padding:3px 9px;border-radius:4px;text-transform:uppercase;z-index:1;">
              {cat.badge}
            </span>
            <!-- Icono bottom-right -->
            <div style="position:absolute;bottom:12px;right:12px;width:36px;height:36px;border-radius:8px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.25);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);z-index:1;">
              <svg width="18" height="18" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
                <Fragment set:html={cat.icon} />
              </svg>
            </div>
          </div>

          <!-- Body -->
          <div style="padding:24px;display:flex;flex-direction:column;gap:0;flex:1;">

            <!-- Título -->
            <h3 style="font-size:1.05rem;font-weight:700;color:#09090b;margin:0 0 10px;line-height:1.3;">
              {cat.title}
            </h3>

            <!-- Descripción -->
            <p style="font-size:0.78rem;color:#71717a;line-height:1.7;margin:0 0 18px;">
              {cat.desc}
            </p>

            <!-- Separador + label Productos -->
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
              <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#a1a1aa;">Productos</span>
              <div style="flex:1;height:1px;background:#f4f4f5;"></div>
            </div>

            <!-- Productos: grid 2 columnas de pills -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:18px;">
              {cat.products.map(prod => (
                <span style="font-size:0.68rem;color:#3f3f46;background:#f4f4f5;padding:5px 8px;border-radius:5px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;line-height:1.4;">
                  {prod}
                </span>
              ))}
            </div>

            <!-- Separador + label Aplica para -->
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
              <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#a1a1aa;">Aplica para</span>
              <div style="flex:1;height:1px;background:#f4f4f5;"></div>
            </div>

            <!-- Sector tags -->
            <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:18px;">
              {cat.sectors.map(s => (
                <span style="font-size:0.67rem;color:#52525b;background:#fff;border:1px solid #e4e4e7;padding:4px 9px;border-radius:99px;line-height:1.4;">
                  {s}
                </span>
              ))}
            </div>

            <!-- Highlight -->
            <div style="display:flex;align-items:center;gap:7px;padding:9px 12px;border-radius:8px;background:#fef2f2;margin-bottom:0;">
              <svg width="12" height="12" fill="#dc2626" viewBox="0 0 20 20" flex-shrink="0">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span style="font-size:0.68rem;font-weight:600;color:#dc2626;">{cat.highlight}</span>
            </div>

            <!-- CTA link -->
            <a
              href={`https://wa.me/525500000000?text=Hola%2C%20necesito%20cotizar%20${cat.link}`}
              target="_blank"
              rel="noopener"
              style="margin-top:auto;padding-top:16px;margin-top:18px;border-top:1px solid #f4f4f5;display:flex;align-items:center;justify-content:space-between;font-size:0.8rem;font-weight:600;color:#dc2626;text-decoration:none;"
            >
              <span>Cotizar {cat.title}</span>
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>
