---
/**
 * CTAWhatsApp — Bloque de conversión principal
 * Diseño limpio: fondo rojo sólido, dos columnas, sin recarga visual
 */
---

<section style="background:#dc2626; padding:80px 0;">
  <div class="container-custom">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:48px;flex-wrap:wrap;">

      <!-- Izquierda: texto -->
      <div style="flex:1;min-width:280px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:18px;">
          <span style="display:block; width:20px; height:2px; background:rgba(255,255,255,0.5); flex-shrink:0; border-radius:2px;"></span>
          <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:rgba(255,255,255,0.65);">Atención especializada</span>
        </div>
        <h2 style="font-size:clamp(1.7rem,3vw,2.4rem);font-weight:800;color:#fff;line-height:1.12;margin:0 0 16px;letter-spacing:-0.02em;">
          ¿Necesitas equipo<br>contra incendios?
        </h2>
        <p style="font-size:0.95rem;color:rgba(255,255,255,0.75);line-height:1.8;margin:0;max-width:420px;">
          Cotiza ahora por WhatsApp. Respuesta en menos de 2 horas.
          Especialistas técnicos te guían en la selección del equipo correcto.
        </p>

        <!-- Trust items -->
        <div style="display:flex;flex-wrap:wrap;gap:20px;margin-top:24px;">
          {['Sin compromiso', 'Precios transparentes', 'Fichas técnicas incluidas'].map(t => (
            <div style="display:flex;align-items:center;gap:7px;">
              <svg width="14" height="14" fill="rgba(255,255,255,0.5)" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span style="font-size:0.8rem;color:rgba(255,255,255,0.7);">{t}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Derecha: CTAs -->
      <div style="display:flex;flex-direction:column;gap:12px;flex-shrink:0;min-width:260px;">

        <!-- WhatsApp — primario -->
        <a
          href="https://wa.me/525500000000?text=Hola%20FIREFIGHTER%2C%20necesito%20cotizar%20equipo%20contra%20incendios"
          target="_blank"
          rel="noopener"
          style="display:flex;align-items:center;gap:14px;padding:18px 22px;border-radius:12px;background:#fff;text-decoration:none;"
        >
          <svg width="28" height="28" fill="#16a34a" viewBox="0 0 24 24" flex-shrink="0" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <div>
            <div style="font-size:0.92rem;font-weight:700;color:#09090b;line-height:1.2;">Cotizar por WhatsApp</div>
            <div style="font-size:0.75rem;color:#71717a;margin-top:2px;">Respuesta en menos de 2 horas</div>
          </div>
        </a>

        <!-- Teléfono + Email — secundarios -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <a
            href="tel:+525512345678"
            style="display:flex;align-items:center;gap:10px;padding:13px 16px;border-radius:10px;border:1px solid rgba(255,255,255,0.25);text-decoration:none;"
          >
            <svg width="16" height="16" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span style="font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.85);">Llamar</span>
          </a>
          <a
            href="mailto:ventas@firefighter.com.mx"
            style="display:flex;align-items:center;gap:10px;padding:13px 16px;border-radius:10px;border:1px solid rgba(255,255,255,0.25);text-decoration:none;"
          >
            <svg width="16" height="16" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span style="font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.85);">Email</span>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Floating WhatsApp -->
<a
  href="https://wa.me/525500000000?text=Hola%20FIREFIGHTER%2C%20necesito%20informaci%C3%B3n%20sobre%20equipos%20contra%20incendios"
  target="_blank"
  rel="noopener"
  style="position:fixed;bottom:24px;right:24px;z-index:50;width:52px;height:52px;border-radius:50%;background:#16a34a;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(22,163,74,0.45);"
  aria-label="Contactar por WhatsApp"
>
  <svg width="24" height="24" fill="white" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>
