---
/**
 * StatsCounter Component - Clean Professional Design
 * Key statistics displayed in a simple banner
 */

const stats = [
  { value: '500+', label: 'Productos en Catálogo' },
  { value: '15+', label: 'Años de Experiencia' },
  { value: '32', label: 'Estados con Entrega' },
  { value: '24h', label: 'Tiempo de Cotización' },
];
---

<section class="py-14 md:py-16" style="background-color: #dc2626;">
  <div class="container-custom">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold mb-1" style="color: #ffffff;">
            {stat.value}
          </div>
          <div class="text-sm" style="color: rgba(255,255,255,0.85);">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
