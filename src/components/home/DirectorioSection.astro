---
/**
 * DirectorioSection - Sección del directorio de estaciones de bomberos
 * Mantenemos el directorio como sección complementaria del sitio comercial
 */
import { getCollection } from 'astro:content';

const stations = await getCollection('stations');
const stateCount = new Set(stations.map(s => s.data.stateSlug)).size;
---

<section id="directorio" class="py-20 md:py-28" style="background-color: #f8fafc;">
  <div class="container-custom">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background-color: #0f172a; border: 1px solid #1e293b;">
          <svg class="w-4 h-4" style="color: #dc2626;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <span class="text-sm font-semibold" style="color: #94a3b8;">Directorio Nacional</span>
        </div>
        <h2 class="font-bold mb-3" style="font-size: clamp(1.75rem, 3vw, 2.5rem); color: #0f172a;">
          Directorio de Estaciones<br>de Bomberos en México
        </h2>
        <p class="text-base max-w-xl" style="color: #64748b;">
          Encuentra {stations.length}+ estaciones de bomberos en {stateCount} estados.
          Directorio con información de contacto, ubicación y servicios de emergencia.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 flex-shrink-0">
        <a
          href="/mapa"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-colors"
          style="background-color: #f1f5f9; color: #475569; border: 1px solid #e2e8f0;"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          Ver Mapa
        </a>
        <a
          href="/directorio"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-colors"
          style="background-color: #0f172a; color: white;"
        >
          Ver Directorio Completo
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Info Strip -->
    <div class="grid grid-cols-3 md:grid-cols-3 gap-4 mb-10">
      {[
        { n: `${stations.length}+`, label: 'Estaciones Registradas', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>` },
        { n: `${stateCount}`, label: 'Estados Cubiertos', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>` },
        { n: '911', label: 'Línea de Emergencias', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>` },
      ].map(stat => (
        <div class="rounded-2xl p-5 text-center" style="background-color: #0f172a;">
          <div class="flex justify-center mb-2">
            <svg class="w-5 h-5" style="color: #dc2626;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={stat.icon} />
            </svg>
          </div>
          <div class="text-2xl font-bold text-white mb-1">{stat.n}</div>
          <div class="text-xs" style="color: #64748b;">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Emergency callout -->
    <div class="rounded-2xl p-5 flex flex-col sm:flex-row items-center justify-between gap-4" style="background-color: #fef2f2; border: 1px solid #fecaca;">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #dc2626;">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-sm" style="color: #991b1b;">¿Tienes una emergencia ahora mismo?</p>
          <p class="text-xs" style="color: #b91c1c;">Llama inmediatamente al número nacional de emergencias</p>
        </div>
      </div>
      <a
        href="tel:911"
        class="flex items-center gap-2 px-6 py-3 rounded-xl font-bold text-white flex-shrink-0"
        style="background-color: #dc2626;"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Llamar al 911
      </a>
    </div>
  </div>
</section>
