---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import Badge from '../../components/ui/Badge.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

// Related articles: share at least 1 tag, exclude current
const related = allPosts
  .filter(p => p.id !== post.id && !p.data.draft)
  .map(p => ({
    post: p,
    shared: p.data.tags.filter(t => post.data.tags.includes(t)).length,
  }))
  .filter(x => x.shared > 0)
  .sort((a, b) => b.shared - a.shared)
  .slice(0, 5)
  .map(x => x.post);

// Recent articles (excluding current)
const recent = allPosts
  .filter(p => p.id !== post.id && !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 4);

const categories = [
  { slug: 'equipos-bomberos', label: 'Equipos para Bomberos', badge: 'NFPA 1971' },
  { slug: 'scba-respiracion', label: 'SCBA y Respiración', badge: 'NFPA 1981' },
  { slug: 'extintores', label: 'Extintores', badge: 'NOM-154' },
  { slug: 'sistemas-fijos', label: 'Sistemas Fijos', badge: 'NFPA 13' },
  { slug: 'herramientas-rescate', label: 'Herramientas de Rescate', badge: 'NFPA 1936' },
  { slug: 'deteccion-alarma', label: 'Detección y Alarma', badge: 'NFPA 72' },
  { slug: 'gabinetes-mangueras', label: 'Gabinetes y Mangueras', badge: 'NOM-002' },
  { slug: 'equipo-forestal', label: 'Equipo Forestal', badge: 'NFPA 1977' },
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  type="article"
>
  <section style="background:#f8fafc; padding:64px 0 96px; border-top:1px solid #e4e4e7;">
    <div class="container-custom">

      <Breadcrumbs
        items={[
          { label: 'Blog', href: '/blog' },
          { label: post.data.title },
        ]}
      />

      <div style="display:grid; grid-template-columns:1fr; gap:40px;" class="lg:grid-cols-[1fr_340px]">

        <!-- MAIN ARTICLE -->
        <article>
          <header style="margin-bottom:32px;">
            <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:16px;">
              {post.data.tags.map((tag) => (
                <Badge variant="fire" size="sm">{tag}</Badge>
              ))}
            </div>

            <h1 style="font-size:clamp(1.7rem,3vw,2.4rem); font-weight:800; color:#09090b; line-height:1.15; letter-spacing:-0.02em; margin:0 0 16px;">
              {post.data.title}
            </h1>

            <p style="font-size:1.1rem; color:#52525b; line-height:1.7; margin:0 0 20px;">
              {post.data.description}
            </p>

            <div style="display:flex; align-items:center; gap:16px; font-size:0.8rem; color:#a1a1aa; padding-bottom:24px; border-bottom:1px solid #e4e4e7;">
              <span style="display:flex; align-items:center; gap:6px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                {post.data.author}
              </span>
              <span style="display:flex; align-items:center; gap:6px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                {new Date(post.data.pubDate).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </div>
          </header>

          {post.data.image && (
            <img
              src={post.data.image}
              alt={post.data.imageAlt || post.data.title}
              style="width:100%; border-radius:12px; margin-bottom:32px;"
            />
          )}

          <div style="background:#fff; border:1px solid #e4e4e7; border-radius:14px; padding:40px 48px;">
            <div class="prose prose-lg prose-slate max-w-none">
              <Content />
            </div>
          </div>

          <!-- Article footer nav -->
          <div style="margin-top:32px; padding-top:32px; border-top:1px solid #e4e4e7; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
            <a href="/blog" style="display:inline-flex; align-items:center; gap:8px; font-size:0.85rem; font-weight:600; color:#52525b; text-decoration:none; padding:10px 18px; border:1px solid #e4e4e7; border-radius:8px; background:#fff; transition:all 0.2s;">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
              Todos los artículos
            </a>
            <a href="/contacto" style="display:inline-flex; align-items:center; gap:8px; font-size:0.85rem; font-weight:700; color:#fff; text-decoration:none; padding:10px 20px; border-radius:8px; background:#dc2626; transition:all 0.2s;">
              Solicitar cotización
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </article>

        <!-- SIDEBAR -->
        <aside>

          <!-- CTA WhatsApp -->
          <div style="background:#09090b; border-radius:14px; padding:28px 24px; margin-bottom:24px; text-align:center;">
            <div style="display:flex; align-items:center; gap:8px; justify-content:center; margin-bottom:12px;">
              <span style="width:8px; height:8px; background:#22c55e; border-radius:50%; display:block;"></span>
              <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#a1a1aa;">Asesoría disponible</span>
            </div>
            <p style="font-size:1rem; font-weight:700; color:#fff; margin:0 0 6px; line-height:1.3;">¿Necesitas equipamiento para tu brigada?</p>
            <p style="font-size:0.78rem; color:#71717a; margin:0 0 20px; line-height:1.6;">Cotización en menos de 24 horas hábiles. Cobertura en los 32 estados.</p>
            <a
              href="https://wa.me/525500000000?text=Hola%2C%20me%20interesa%20cotizar%20equipos%20contra%20incendios."
              target="_blank"
              rel="noopener"
              style="display:flex; align-items:center; justify-content:center; gap:8px; background:#25D366; color:#fff; font-size:0.85rem; font-weight:700; padding:12px 20px; border-radius:8px; text-decoration:none; margin-bottom:10px;"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
            <a href="/contacto" style="display:block; font-size:0.78rem; color:#a1a1aa; text-decoration:underline;">
              o enviar solicitud formal
            </a>
          </div>

          <!-- Categorías de productos -->
          <div style="background:#fff; border:1px solid #e4e4e7; border-radius:14px; padding:24px; margin-bottom:24px;">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
              <span style="display:block; width:20px; height:2px; background:#dc2626; border-radius:2px; flex-shrink:0;"></span>
              <span style="font-size:0.68rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#dc2626;">Catálogo de productos</span>
            </div>
            <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:4px;">
              {categories.map(cat => (
                <li>
                  <a
                    href={`/productos/${cat.slug}`}
                    style="display:flex; align-items:center; justify-content:space-between; padding:10px 12px; border-radius:8px; text-decoration:none; transition:background 0.15s;"
                    class="hover:bg-slate-50"
                  >
                    <span style="font-size:0.82rem; font-weight:600; color:#09090b;">{cat.label}</span>
                    <span style="font-size:0.62rem; font-weight:700; background:#fef2f2; color:#dc2626; padding:2px 7px; border-radius:4px; letter-spacing:0.04em;">{cat.badge}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Artículos relacionados -->
          {related.length > 0 && (
            <div style="background:#fff; border:1px solid #e4e4e7; border-radius:14px; padding:24px; margin-bottom:24px;">
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
                <span style="display:block; width:20px; height:2px; background:#dc2626; border-radius:2px; flex-shrink:0;"></span>
                <span style="font-size:0.68rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#dc2626;">Artículos relacionados</span>
              </div>
              <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:0;">
                {related.map((p, i) => (
                  <li style={i > 0 ? "border-top:1px solid #f4f4f5;" : ""}>
                    <a
                      href={`/blog/${p.id}`}
                      style="display:block; padding:12px 0; text-decoration:none;"
                    >
                      <p style="font-size:0.82rem; font-weight:600; color:#09090b; margin:0 0 4px; line-height:1.35; transition:color 0.15s;" class="hover:text-red-600">{p.data.title}</p>
                      <p style="font-size:0.72rem; color:#a1a1aa; margin:0;">{new Date(p.data.pubDate).toLocaleDateString('es-MX', { year:'numeric', month:'short', day:'numeric' })}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Artículos recientes -->
          {recent.length > 0 && (
            <div style="background:#fff; border:1px solid #e4e4e7; border-radius:14px; padding:24px; margin-bottom:24px;">
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
                <span style="display:block; width:20px; height:2px; background:#dc2626; border-radius:2px; flex-shrink:0;"></span>
                <span style="font-size:0.68rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#dc2626;">Publicaciones recientes</span>
              </div>
              <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:0;">
                {recent.map((p, i) => (
                  <li style={i > 0 ? "border-top:1px solid #f4f4f5;" : ""}>
                    <a
                      href={`/blog/${p.id}`}
                      style="display:block; padding:12px 0; text-decoration:none;"
                    >
                      <p style="font-size:0.82rem; font-weight:600; color:#09090b; margin:0 0 4px; line-height:1.35;" class="hover:text-red-600">{p.data.title}</p>
                      <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:6px;">
                        {p.data.tags.slice(0,2).map(tag => (
                          <span style="font-size:0.65rem; background:#f4f4f5; color:#52525b; padding:2px 7px; border-radius:4px;">{tag}</span>
                        ))}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Licitaciones CTA -->
          <div style="background:#fef2f2; border:1px solid #fecaca; border-radius:14px; padding:24px; text-align:center;">
            <svg width="32" height="32" fill="#dc2626" viewBox="0 0 20 20" style="margin:0 auto 12px;"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
            <p style="font-size:0.85rem; font-weight:700; color:#09090b; margin:0 0 6px;">¿Licitación pública?</p>
            <p style="font-size:0.75rem; color:#52525b; margin:0 0 16px; line-height:1.6;">Documentación técnica completa para CompraNet y licitaciones estatales.</p>
            <a href="mailto:licitaciones@firefighter.mx" style="display:block; font-size:0.8rem; font-weight:700; color:#dc2626; text-decoration:none; padding:10px; border:1px solid #fca5a5; border-radius:8px; background:#fff;">
              licitaciones@firefighter.mx
            </a>
          </div>

        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .prose h2 {
    @apply text-2xl font-display font-semibold text-slate-800 mt-8 mb-4;
  }
  .prose h3 {
    @apply text-xl font-display font-semibold text-slate-700 mt-6 mb-3;
  }
  .prose p {
    @apply text-slate-600 mb-4 leading-relaxed;
  }
  .prose ul, .prose ol {
    @apply space-y-2 mb-6 pl-6;
  }
  .prose li {
    @apply text-slate-600;
  }
  .prose strong {
    @apply text-slate-800;
  }
  .prose a {
    @apply text-red-600 hover:text-red-700 underline;
  }
  .prose blockquote {
    @apply border-l-4 border-red-500 pl-6 italic text-slate-600 my-6;
  }
  .prose table {
    @apply w-full text-sm border-collapse mb-6;
  }
  .prose thead th {
    @apply bg-slate-800 text-white font-semibold px-4 py-3 text-left;
  }
  .prose tbody tr:nth-child(even) {
    @apply bg-slate-50;
  }
  .prose tbody td {
    @apply px-4 py-3 text-slate-600 border-b border-slate-200;
  }

  @media (max-width: 1023px) {
    aside {
      order: -1;
    }
  }
</style>
