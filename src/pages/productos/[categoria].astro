---
import BaseLayout from '../../layouts/BaseLayout.astro';
import categorias from '../../data/productos.json';

export function getStaticPaths() {
  return categorias.map(cat => ({
    params: { categoria: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const waBase = 'https://wa.me/525500000000';
const otrasCategs = categorias.filter(c => c.slug !== cat.slug);
---

<BaseLayout
  title={`${cat.nombre} — FIREFIGHTER México | Equipos Certificados ${cat.badge}`}
  description={cat.descripcion}
>

  <!-- ══ HERO CATEGORÍA ══ -->
  <section style="background:#09090b; padding:64px 0 52px; border-bottom:1px solid #1f1f1f;">
    <div class="container-custom">

      <!-- Breadcrumb -->
      <div style="display:flex; align-items:center; gap:8px; margin-bottom:28px; flex-wrap:wrap;">
        <a href="/" style="font-size:0.72rem; color:#71717a; text-decoration:none; transition:color 0.2s;"
           onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#71717a'">Inicio</a>
        <svg width="12" height="12" fill="none" stroke="#3f3f46" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="/productos" style="font-size:0.72rem; color:#71717a; text-decoration:none; transition:color 0.2s;"
           onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#71717a'">Catálogo</a>
        <svg width="12" height="12" fill="none" stroke="#3f3f46" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span style="font-size:0.72rem; color:#a1a1aa; font-weight:600;">{cat.nombre}</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12" style="align-items:center;">

        <div>
          <span style="display:inline-block; background:#dc2626; color:#fff; font-size:0.65rem; font-weight:800; letter-spacing:0.08em; padding:4px 12px; border-radius:4px; text-transform:uppercase; margin-bottom:20px;">
            {cat.badge}
          </span>
          <h1 style="font-size:clamp(1.8rem,3vw,2.8rem); font-weight:800; color:#fff; line-height:1.1; margin:0 0 20px; letter-spacing:-0.02em;">
            {cat.nombre}
          </h1>
          <p style="font-size:0.9rem; color:#71717a; line-height:1.85; margin:0 0 28px; max-width:480px;">
            {cat.descripcion}
          </p>
          <div style="display:flex; gap:12px; flex-wrap:wrap;">
            <a
              href={`${waBase}?text=Hola%2C%20necesito%20cotizar%20${encodeURIComponent(cat.nombre)}`}
              target="_blank"
              rel="noopener"
              style="display:inline-flex; align-items:center; gap:8px; padding:13px 24px; background:#dc2626; color:#fff; font-size:0.85rem; font-weight:700; border-radius:9px; text-decoration:none; transition:background 0.2s;"
              onmouseover="this.style.background='#b91c1c'" onmouseout="this.style.background='#dc2626'"
            >
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Solicitar cotización
            </a>
            <a
              href="mailto:ventas@firefighter.mx"
              style="display:inline-flex; align-items:center; gap:8px; padding:13px 24px; background:transparent; color:#a1a1aa; font-size:0.85rem; font-weight:600; border-radius:9px; text-decoration:none; border:1px solid #2a2a2a; transition:border-color 0.2s, color 0.2s;"
              onmouseover="this.style.borderColor='#71717a'; this.style.color='#fff';"
              onmouseout="this.style.borderColor='#2a2a2a'; this.style.color='#a1a1aa';"
            >
              ventas@firefighter.mx
            </a>
          </div>
        </div>

        <!-- Info rápida -->
        <div style="background:#111; border:1px solid #1f1f1f; border-radius:14px; padding:28px 32px; display:flex; flex-direction:column; gap:18px;">
          <div>
            <span style="font-size:0.62rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#3f3f46; display:block; margin-bottom:8px;">Norma aplicable</span>
            <span style="font-size:0.9rem; font-weight:700; color:#dc2626;">{cat.norma}</span>
          </div>
          <div style="height:1px; background:#1f1f1f;"></div>
          <div>
            <span style="font-size:0.62rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#3f3f46; display:block; margin-bottom:10px;">Sectores que aplica</span>
            <div style="display:flex; flex-wrap:wrap; gap:6px;">
              {cat.sector.map(s => (
                <span style="font-size:0.7rem; color:#a1a1aa; background:#1a1a1a; border:1px solid #2a2a2a; padding:4px 10px; border-radius:99px;">{s}</span>
              ))}
            </div>
          </div>
          <div style="height:1px; background:#1f1f1f;"></div>
          <div>
            <span style="font-size:0.62rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#3f3f46; display:block; margin-bottom:8px;">Productos disponibles</span>
            <span style="font-size:1.6rem; font-weight:800; color:#fff; letter-spacing:-0.02em;">{cat.productos.length}</span>
            <span style="font-size:0.75rem; color:#52525b; margin-left:6px;">en esta categoría</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ GRID DE PRODUCTOS ══ -->
  <section style="background:#f8fafc; padding:72px 0 96px;">
    <div class="container-custom">

      <div style="margin-bottom:40px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
          <span style="display:block; width:24px; height:2px; background:#dc2626; flex-shrink:0; border-radius:2px;"></span>
          <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#dc2626;">Productos</span>
        </div>
        <h2 style="font-size:clamp(1.5rem,2.4vw,2.2rem); font-weight:800; color:#09090b; line-height:1.1; margin:0; letter-spacing:-0.02em;">
          {cat.nombre} — Catálogo completo
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {cat.productos.map(prod => (
          <div style="background:#fff; border:1px solid #e4e4e7; border-radius:14px; overflow:hidden; display:flex; flex-direction:column; transition:box-shadow 0.2s ease, transform 0.2s ease;"
               class="hover:-translate-y-1 hover:shadow-lg">

            <!-- Header producto -->
            <div style="padding:24px 24px 0;">
              <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; flex-wrap:wrap; gap:6px;">
                <span style="display:inline-block; background:#dc2626; color:#fff; font-size:0.6rem; font-weight:800; letter-spacing:0.06em; padding:3px 9px; border-radius:4px; text-transform:uppercase;">
                  {prod.norma}
                </span>
                <span style="font-size:0.65rem; font-weight:700; color:#52525b; background:#f4f4f5; padding:3px 8px; border-radius:4px;">
                  {prod.marca}
                </span>
              </div>
              <h3 style="font-size:1rem; font-weight:700; color:#09090b; margin:0 0 10px; line-height:1.3;">
                {prod.nombre}
              </h3>
              <p style="font-size:0.77rem; color:#71717a; line-height:1.7; margin:0 0 18px;">
                {prod.descripcion}
              </p>
            </div>

            <!-- Body producto -->
            <div style="padding:0 24px 24px; display:flex; flex-direction:column; flex:1;">

              <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
                <span style="font-size:0.62rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#a1a1aa;">Características</span>
                <div style="flex:1; height:1px; background:#f4f4f5;"></div>
              </div>
              <div style="display:flex; flex-direction:column; gap:5px; margin-bottom:18px;">
                {prod.caracteristicas.map(c => (
                  <div style="display:flex; align-items:flex-start; gap:8px;">
                    <svg width="10" height="10" fill="#dc2626" viewBox="0 0 20 20" style="flex-shrink:0; margin-top:3px;">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span style="font-size:0.72rem; color:#3f3f46; line-height:1.5;">{c}</span>
                  </div>
                ))}
              </div>

              <!-- Aplicación -->
              <div style="display:flex; align-items:center; gap:7px; padding:9px 12px; border-radius:8px; background:#fef2f2; margin-bottom:18px;">
                <svg width="12" height="12" fill="#dc2626" viewBox="0 0 20 20" style="flex-shrink:0;">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span style="font-size:0.68rem; font-weight:600; color:#dc2626;">{prod.aplicacion}</span>
              </div>

              <!-- CTA -->
              <a
                href={`${waBase}?text=Hola%2C%20necesito%20cotizar%20*${encodeURIComponent(prod.nombre)}*%20de%20${encodeURIComponent(prod.marca)}.%20Norma%3A%20${encodeURIComponent(prod.norma)}`}
                target="_blank"
                rel="noopener"
                style="margin-top:auto; border-top:1px solid #f4f4f5; padding-top:16px; display:flex; align-items:center; justify-content:space-between; font-size:0.8rem; font-weight:600; color:#dc2626; text-decoration:none;"
              >
                <span>Solicitar cotización</span>
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>

            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ══ OTRAS CATEGORÍAS ══ -->
  <section style="background:#fff; padding:72px 0; border-top:1px solid #e4e4e7;">
    <div class="container-custom">

      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:36px; flex-wrap:wrap; gap:12px;">
        <div>
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
            <span style="display:block; width:24px; height:2px; background:#dc2626; flex-shrink:0; border-radius:2px;"></span>
            <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#dc2626;">Más categorías</span>
          </div>
          <h2 style="font-size:clamp(1.3rem,2vw,1.8rem); font-weight:800; color:#09090b; margin:0; letter-spacing:-0.02em;">
            Explora el catálogo completo
          </h2>
        </div>
        <a href="/productos" style="font-size:0.8rem; font-weight:600; color:#dc2626; text-decoration:none; display:flex; align-items:center; gap:6px;">
          Ver todas
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {otrasCategs.slice(0, 4).map(c => (
          <a
            href={`/productos/${c.slug}`}
            style="background:#f8fafc; border:1px solid #e4e4e7; border-radius:12px; padding:20px; display:flex; flex-direction:column; gap:10px; text-decoration:none; transition:box-shadow 0.2s ease, transform 0.2s ease;"
            class="hover:-translate-y-1 hover:shadow-md"
          >
            <span style="display:inline-block; background:#dc2626; color:#fff; font-size:0.6rem; font-weight:800; letter-spacing:0.06em; padding:3px 8px; border-radius:4px; text-transform:uppercase; width:fit-content;">
              {c.badge}
            </span>
            <span style="font-size:0.9rem; font-weight:700; color:#09090b; line-height:1.3;">{c.nombre}</span>
            <span style="font-size:0.72rem; color:#71717a; line-height:1.5;">{c.productos.length} productos disponibles</span>
            <div style="display:flex; align-items:center; gap:6px; font-size:0.75rem; font-weight:600; color:#dc2626; margin-top:4px;">
              Ver productos
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ══ CTA FINAL ══ -->
  <section style="background:#09090b; padding:64px 0; border-top:1px solid #1f1f1f;">
    <div class="container-custom" style="text-align:center;">
      <div style="display:inline-flex; align-items:center; gap:10px; margin-bottom:20px;">
        <span style="display:block; width:24px; height:2px; background:#dc2626; border-radius:2px;"></span>
        <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#dc2626;">Asesoría sin costo</span>
        <span style="display:block; width:24px; height:2px; background:#dc2626; border-radius:2px;"></span>
      </div>
      <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:800; color:#fff; line-height:1.1; margin:0 0 16px; letter-spacing:-0.02em;">
        ¿Necesitas asesoría técnica<br>para seleccionar el equipo correcto?
      </h2>
      <p style="font-size:0.9rem; color:#71717a; line-height:1.85; margin:0 0 32px; max-width:520px; margin-left:auto; margin-right:auto;">
        Ingenieros especializados en <strong style="color:#a1a1aa;">NFPA y NOM-002-STPS</strong> analizan tu riesgo y te recomiendan el equipo exacto. Sin costo, sin compromiso de compra.
      </p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a
          href={`${waBase}?text=Hola%2C%20necesito%20asesor%C3%ADa%20t%C3%A9cnica%20para%20${encodeURIComponent(cat.nombre)}`}
          target="_blank"
          rel="noopener"
          style="display:inline-flex; align-items:center; gap:10px; padding:14px 28px; background:#dc2626; color:#fff; font-size:0.9rem; font-weight:700; border-radius:10px; text-decoration:none;"
        >
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hablar con un especialista
        </a>
        <a
          href="/productos"
          style="display:inline-flex; align-items:center; gap:10px; padding:14px 28px; background:transparent; color:#a1a1aa; font-size:0.9rem; font-weight:600; border-radius:10px; text-decoration:none; border:1px solid #2a2a2a;"
        >
          Ver catálogo completo
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
