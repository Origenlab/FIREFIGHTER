---
import BaseLayout from '../../layouts/BaseLayout.astro';
import categorias from '../../data/productos.json';

const normas = [...new Set(categorias.map(c => c.norma))];
const sectores = [...new Set(categorias.flatMap(c => c.sector))];

const waBase = 'https://wa.me/525500000000';
---

<BaseLayout
  title="Catálogo de Productos — FIREFIGHTER México | Equipos Contra Incendios"
  description="Catálogo completo de equipos contra incendios y equipos para bomberos certificados NFPA, NOM y UL. Extintores, SCBA, trajes, sistemas fijos, herramientas de rescate y más."
>

  <!-- ══ HERO MINI ══ -->
  <section style="background:#09090b; padding:72px 0 56px; border-bottom:1px solid #1f1f1f;">
    <div class="container-custom">

      <!-- Breadcrumb -->
      <div style="display:flex; align-items:center; gap:8px; margin-bottom:28px;">
        <a href="/" style="font-size:0.72rem; color:#71717a; text-decoration:none; transition:color 0.2s;"
           onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#71717a'">Inicio</a>
        <svg width="12" height="12" fill="none" stroke="#3f3f46" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span style="font-size:0.72rem; color:#a1a1aa; font-weight:600;">Catálogo de Productos</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12" style="align-items:center;">
        <div>
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
            <span style="display:block; width:24px; height:2px; background:#dc2626; flex-shrink:0; border-radius:2px;"></span>
            <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#dc2626;">Catálogo Completo</span>
          </div>
          <h1 style="font-size:clamp(2rem,3.2vw,3rem); font-weight:800; color:#fff; line-height:1.05; margin:0; letter-spacing:-0.02em;">
            Equipos certificados<br>para cada operación
          </h1>
          <p style="font-size:0.9rem; color:#71717a; line-height:1.85; margin:24px 0 0; max-width:480px;">
            Distribuidores autorizados de <strong style="color:#a1a1aa; font-weight:600;">MSA Safety, Scott, Holmatro y Amerex</strong>. Más de 8 categorías de producto con certificación NFPA, NOM y UL.
          </p>
        </div>

        <!-- Stats strip dark -->
        <div class="grid grid-cols-2 gap-px" style="background:#1f1f1f; border:1px solid #1f1f1f; border-radius:14px; overflow:hidden;">
          {[
            { n: '8', label: 'Categorías de producto', sub: 'en catálogo' },
            { n: '48+', label: 'Productos disponibles', sub: 'ejemplo representativo' },
            { n: 'NFPA', label: 'Norma principal', sub: 'y NOM / UL Listed' },
            { n: '<24h', label: 'Tiempo de cotización', sub: 'propuesta técnica' },
          ].map(s => (
            <div style="background:#111; padding:24px 20px; text-align:center;">
              <div style="font-size:1.6rem; font-weight:800; color:#fff; line-height:1; letter-spacing:-0.02em;">{s.n}</div>
              <div style="font-size:0.72rem; font-weight:600; color:#71717a; margin-top:6px;">{s.label}</div>
              <div style="font-size:0.62rem; color:#3f3f46; margin-top:3px;">{s.sub}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FILTROS ══ -->
  <div style="background:#fff; border-bottom:1px solid #e4e4e7; position:sticky; top:0; z-index:40;">
    <div class="container-custom" style="padding-top:0; padding-bottom:0;">
      <div style="display:flex; flex-wrap:wrap; align-items:center; gap:0; padding:0; overflow-x:auto;">

        <!-- Tab: Todas -->
        <button
          class="filter-tab active"
          data-filter="categoria"
          data-value="todas"
          style="padding:16px 20px; font-size:0.78rem; font-weight:600; color:#dc2626; border:none; background:transparent; border-bottom:2px solid #dc2626; cursor:pointer; white-space:nowrap; transition:color 0.2s, border-color 0.2s; flex-shrink:0;"
        >Todas</button>

        {categorias.map(c => (
          <button
            class="filter-tab"
            data-filter="categoria"
            data-value={c.slug}
            style="padding:16px 20px; font-size:0.78rem; font-weight:600; color:#71717a; border:none; background:transparent; border-bottom:2px solid transparent; cursor:pointer; white-space:nowrap; transition:color 0.2s, border-color 0.2s; flex-shrink:0;"
          >{c.nombre}</button>
        ))}

      </div>
    </div>

    <!-- Sub-filtros norma + sector -->
    <div style="background:#f8fafc; border-top:1px solid #e4e4e7; padding:12px 0;">
      <div class="container-custom" style="padding-top:0; padding-bottom:0;">
        <div style="display:flex; flex-wrap:wrap; align-items:center; gap:8px;">

          <span style="font-size:0.62rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#a1a1aa; flex-shrink:0;">Norma:</span>
          <button class="filter-pill active" data-filter="norma" data-value="todas"
            style="font-size:0.68rem; font-weight:600; padding:5px 12px; border-radius:99px; border:1px solid #dc2626; background:#dc2626; color:#fff; cursor:pointer; transition:all 0.2s; white-space:nowrap;">
            Todas
          </button>
          {normas.map(n => (
            <button class="filter-pill" data-filter="norma" data-value={n}
              style="font-size:0.68rem; font-weight:600; padding:5px 12px; border-radius:99px; border:1px solid #e4e4e7; background:#fff; color:#52525b; cursor:pointer; transition:all 0.2s; white-space:nowrap;">
              {n}
            </button>
          ))}

          <span style="width:1px; height:20px; background:#e4e4e7; margin:0 4px; flex-shrink:0;"></span>

          <span style="font-size:0.62rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#a1a1aa; flex-shrink:0;">Sector:</span>
          <button class="filter-pill active" data-filter="sector" data-value="todas"
            style="font-size:0.68rem; font-weight:600; padding:5px 12px; border-radius:99px; border:1px solid #dc2626; background:#dc2626; color:#fff; cursor:pointer; transition:all 0.2s; white-space:nowrap;">
            Todos
          </button>
          {sectores.map(s => (
            <button class="filter-pill" data-filter="sector" data-value={s}
              style="font-size:0.68rem; font-weight:600; padding:5px 12px; border-radius:99px; border:1px solid #e4e4e7; background:#fff; color:#52525b; cursor:pointer; transition:all 0.2s; white-space:nowrap;">
              {s}
            </button>
          ))}

        </div>
      </div>
    </div>
  </div>

  <!-- ══ GRID DE CATEGORÍAS ══ -->
  <section style="background:#f8fafc; padding:64px 0 96px;">
    <div class="container-custom">

      <!-- Contador de resultados -->
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:32px; flex-wrap:wrap; gap:12px;">
        <p id="result-count" style="font-size:0.82rem; color:#71717a; margin:0;">
          Mostrando <strong style="color:#09090b;" id="count-num">{categorias.length}</strong> categorías
        </p>
        <a
          href={`${waBase}?text=Hola%2C%20necesito%20una%20cotizaci%C3%B3n%20de%20equipo%20contra%20incendios`}
          target="_blank"
          rel="noopener"
          style="display:inline-flex; align-items:center; gap:8px; padding:10px 20px; background:#dc2626; color:#fff; font-size:0.8rem; font-weight:700; border-radius:8px; text-decoration:none;"
        >
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Cotizar todo
        </a>
      </div>

      <!-- Grid categorías -->
      <div id="cat-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {categorias.map(cat => (
          <div
            class="cat-card"
            data-slug={cat.slug}
            data-norma={cat.norma}
            data-sectores={cat.sector.join('|')}
            style="background:#fff; border:1px solid #e4e4e7; border-radius:14px; overflow:hidden; display:flex; flex-direction:column; transition:box-shadow 0.2s ease, transform 0.2s ease;"
          >
            <!-- Header -->
            <div style="padding:24px 24px 0;">
              <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
                <span style="display:inline-block; background:#dc2626; color:#fff; font-size:0.62rem; font-weight:800; letter-spacing:0.06em; padding:3px 9px; border-radius:4px; text-transform:uppercase;">
                  {cat.badge}
                </span>
                <span style="font-size:0.65rem; font-weight:600; color:#a1a1aa; background:#f4f4f5; padding:3px 8px; border-radius:4px;">
                  {cat.productos.length} productos
                </span>
              </div>
              <h2 style="font-size:1.05rem; font-weight:700; color:#09090b; margin:0 0 10px; line-height:1.3;">
                {cat.nombre}
              </h2>
              <p style="font-size:0.78rem; color:#71717a; line-height:1.7; margin:0 0 18px;">
                {cat.descripcion}
              </p>
            </div>

            <!-- Body -->
            <div style="padding:0 24px 24px; display:flex; flex-direction:column; flex:1;">

              <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
                <span style="font-size:0.62rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#a1a1aa;">Incluye</span>
                <div style="flex:1; height:1px; background:#f4f4f5;"></div>
              </div>
              <div style="display:grid; grid-template-columns:1fr 1fr; gap:5px; margin-bottom:18px;">
                {cat.items.map(item => (
                  <span style="font-size:0.68rem; color:#3f3f46; background:#f4f4f5; padding:5px 8px; border-radius:5px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; line-height:1.4;">
                    {item}
                  </span>
                ))}
              </div>

              <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
                <span style="font-size:0.62rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#a1a1aa;">Aplica para</span>
                <div style="flex:1; height:1px; background:#f4f4f5;"></div>
              </div>
              <div style="display:flex; flex-wrap:wrap; gap:5px; margin-bottom:18px;">
                {cat.sector.map(s => (
                  <span style="font-size:0.67rem; color:#52525b; background:#fff; border:1px solid #e4e4e7; padding:4px 9px; border-radius:99px; line-height:1.4;">
                    {s}
                  </span>
                ))}
              </div>

              <div style="display:flex; align-items:center; gap:7px; padding:9px 12px; border-radius:8px; background:#fef2f2; margin-bottom:18px;">
                <svg width="12" height="12" fill="#dc2626" viewBox="0 0 20 20" style="flex-shrink:0;">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span style="font-size:0.68rem; font-weight:600; color:#dc2626;">{cat.highlight}</span>
              </div>

              <!-- Dos CTAs -->
              <div style="display:flex; gap:8px; margin-top:auto; padding-top:16px; border-top:1px solid #f4f4f5;">
                <a
                  href={`/productos/${cat.slug}`}
                  style="flex:1; display:flex; align-items:center; justify-content:center; gap:6px; padding:10px 14px; background:#09090b; color:#fff; font-size:0.75rem; font-weight:700; border-radius:8px; text-decoration:none; transition:background 0.2s;"
                  onmouseover="this.style.background='#1a1a1a'"
                  onmouseout="this.style.background='#09090b'"
                >
                  Ver productos
                  <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
                <a
                  href={`${waBase}?text=Hola%2C%20necesito%20cotizar%20${encodeURIComponent(cat.nombre)}`}
                  target="_blank"
                  rel="noopener"
                  style="display:flex; align-items:center; justify-content:center; padding:10px 12px; background:#25d366; color:#fff; font-size:0.75rem; font-weight:700; border-radius:8px; text-decoration:none; transition:background 0.2s; flex-shrink:0;"
                  onmouseover="this.style.background='#1ebe5a'"
                  onmouseout="this.style.background='#25d366'"
                  title="Cotizar por WhatsApp"
                >
                  <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </a>
              </div>

            </div>
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" style="display:none; text-align:center; padding:80px 0;">
        <div style="font-size:2.5rem; margin-bottom:16px;">🔍</div>
        <p style="font-size:1rem; font-weight:700; color:#09090b; margin:0 0 8px;">Sin resultados para ese filtro</p>
        <p style="font-size:0.85rem; color:#71717a; margin:0 0 24px;">Intenta con otro sector o norma, o contáctanos directamente.</p>
        <a href={`${waBase}?text=Hola%2C%20busco%20equipo%20espec%C3%ADfico%20contra%20incendios`}
           target="_blank" rel="noopener"
           style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; background:#dc2626; color:#fff; font-size:0.85rem; font-weight:700; border-radius:9px; text-decoration:none;">
          Consultar por WhatsApp
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const activeFilters = { categoria: 'todas', norma: 'todas', sector: 'todas' };

  function applyFilters() {
    const cards = document.querySelectorAll<HTMLElement>('.cat-card');
    let visible = 0;

    cards.forEach(card => {
      const slug    = card.dataset.slug    ?? '';
      const norma   = card.dataset.norma   ?? '';
      const sects   = card.dataset.sectores ?? '';

      const matchCat    = activeFilters.categoria === 'todas' || slug === activeFilters.categoria;
      const matchNorma  = activeFilters.norma     === 'todas' || norma === activeFilters.norma;
      const matchSector = activeFilters.sector    === 'todas' || sects.split('|').includes(activeFilters.sector);

      const show = matchCat && matchNorma && matchSector;
      card.style.display = show ? 'flex' : 'none';
      if (show) visible++;
    });

    const countEl = document.getElementById('count-num');
    if (countEl) countEl.textContent = String(visible);

    const emptyEl = document.getElementById('empty-state') as HTMLElement;
    if (emptyEl) emptyEl.style.display = visible === 0 ? 'block' : 'none';
  }

  // Tabs de categoría
  document.querySelectorAll<HTMLElement>('.filter-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll<HTMLElement>('.filter-tab').forEach(b => {
        b.style.color = '#71717a';
        b.style.borderBottomColor = 'transparent';
        b.classList.remove('active');
      });
      btn.style.color = '#dc2626';
      btn.style.borderBottomColor = '#dc2626';
      btn.classList.add('active');
      activeFilters.categoria = btn.dataset.value ?? 'todas';
      applyFilters();
    });
  });

  // Pills norma + sector
  document.querySelectorAll<HTMLElement>('.filter-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const filterType = btn.dataset.filter as 'norma' | 'sector';
      // Reset pills del mismo grupo
      document.querySelectorAll<HTMLElement>(`.filter-pill[data-filter="${filterType}"]`).forEach(b => {
        b.style.background = '#fff';
        b.style.color = '#52525b';
        b.style.borderColor = '#e4e4e7';
        b.classList.remove('active');
      });
      btn.style.background = '#dc2626';
      btn.style.color = '#fff';
      btn.style.borderColor = '#dc2626';
      btn.classList.add('active');
      activeFilters[filterType] = btn.dataset.value ?? 'todas';
      applyFilters();
    });
  });

  // Hover cards
  document.querySelectorAll<HTMLElement>('.cat-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.transform = 'translateY(-4px)';
      card.style.boxShadow = '0 10px 40px rgba(0,0,0,0.1)';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'translateY(0)';
      card.style.boxShadow = 'none';
    });
  });
</script>
